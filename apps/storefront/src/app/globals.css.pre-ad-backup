@import "tailwindcss";
@source "../../src";

/* ========================================================================
   Untitled UI React – Foundation Layer
   Coexists with existing design system. UUI components use these tokens.
   ======================================================================== */
/* UUI theme.css inlined below for Turbopack compatibility */
@import "../styles/untitled-ui/typography.css";

@plugin "tailwindcss-react-aria-components";
@plugin "tailwindcss-animate";

/* Dark mode variant: activates UUI dark tokens on .dark-mode class
   AND when system prefers dark. This bridges with the project's existing
   prefers-color-scheme dark mode approach. */
@custom-variant dark (&:where(.dark-mode, .dark-mode *));

/* UUI label/focus variants */
@custom-variant label (& [data-label]);
@custom-variant focus-input-within (&:has(input:focus));

/* UUI custom utilities */
@utility scrollbar-hide {
    &::-webkit-scrollbar {
        display: none;
        -webkit-appearance: none;
    }
    -ms-overflow-style: none;
    scrollbar-width: none;
}

@utility transition-inherit-all {
    transition-property: inherit;
    transition-duration: inherit;
    transition-timing-function: inherit;
}



