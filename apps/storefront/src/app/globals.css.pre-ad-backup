   SOTA E-Commerce Template Design System — Tailwind v4 CSS-first config
   ======================================================================== */

/* =========================================================================
   RUNTIME VARS — :root block for component CSS (.btn-primary, etc.)
   These are available at runtime via var(--color-brand) etc.
   ========================================================================= */
:root {
  /* Source-of-truth design tokens */
  --theme-brand: #2D5016;
  --theme-brand-light: #3d6b1e;
  --theme-brand-dark: #234010;
  --theme-brand-subtle: #2d50160a;
  --theme-brand-muted: #2d50161f;
  --theme-brand-emphasis: #2D5016;
  --theme-sec: #8BC34A;
  --theme-sec-light: #9ccc65;
  --theme-accent: #FF9800;
  --theme-accent-light: #ffb74d;
  --theme-sf-0: #ffffff;
  --theme-sf-1: #f8faf6;
  --theme-sf-2: #f0f4ec;
  --theme-sf-3: #e8ede3;
  --theme-glass: rgba(255, 255, 255, 0.7);
  --theme-glass-heavy: rgba(255, 255, 255, 0.85);
  --theme-tx: #1a2e0a;
  --theme-tx-sec: #4a5e3a;
  --theme-tx-muted: #6b7d5c;
  --theme-tx-faint: #8b9c7d;
  --theme-tx-inv: #ffffff;
  --theme-ring-soft: rgba(45, 80, 22, 0.1);
  --theme-ring-med: rgba(45, 80, 22, 0.2);
  --theme-border-soft: #e2e8df;
  --theme-shadow-brand-soft: 0 4px 14px 0 rgba(45, 80, 22, 0.1);

  /* Runtime aliases so component CSS can use var(--color-brand) */
  --color-brand: #2D5016;
  --color-brand-light: #3d6b1e;
  --color-brand-dark: #234010;
  --color-brand-subtle: #2d50160a;
  --color-brand-muted: #2d50161f;
  --color-brand-emphasis: #2D5016;
  --color-sec: #8BC34A;
  --color-sec-light: #9ccc65;
  --color-accent: #FF9800;
  --color-accent-light: #ffb74d;
  --color-sf-0: #ffffff;
  --color-sf-1: #f8faf6;
  --color-sf-2: #f0f4ec;
  --color-sf-3: #e8ede3;
  --color-tx: #1a2e0a;
  --color-tx-sec: #4a5e3a;
  --color-tx-muted: #6b7d5c;
  --color-tx-faint: #8b9c7d;
  --color-tx-inv: #ffffff;

