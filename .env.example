# ============================================
# BootandStrap E-Commerce Template — Environment Variables
# ============================================
# Copy this to .env and fill in your values.
# Lines marked ⚠️ REQUIRED must be set before first run.
# Lines marked 🔒 SECRET should be generated with: openssl rand -base64 32

# ── Supabase (⚠️ REQUIRED) ─────────────────────
# From your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase DB connection (Transaction Pool — used by Medusa)
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Medusa ────────────────────────────────────
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_ONBOARDING_TYPE=default
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:5173,http://localhost:9000

# 🔒 SECRET — generate with: openssl rand -base64 32
COOKIE_SECRET=
JWT_SECRET=

# Medusa Admin credentials (used by Owner Panel's getAdminToken())
# ⚠️ REQUIRED — must match an admin user in Medusa
MEDUSA_ADMIN_EMAIL=admin@medusajs.com
# 🔒 SECRET — generate a strong password, never use defaults
MEDUSA_ADMIN_PASSWORD=

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stripe (optional — use PLACEHOLDER to disable) ──
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER

# ── Resend (Email — optional) ────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── WhatsApp (optional) ──────────────────────
WHATSAPP_PHONE_NUMBER=34600000000
WHATSAPP_DEFAULT_COUNTRY_PREFIX=34

# ── App Config ────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_REGION=es
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your-medusa-publishable-key
# Client-side Medusa API URL (required in production)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NODE_ENV=development

# ── Multi-Tenant (⚠️ REQUIRED) ──────────────
# Server-only tenant ID (config, flags, limits queries)
# Never expose as NEXT_PUBLIC_ — see GEMINI.md invariant #4
TENANT_ID=your-tenant-uuid

# ── Sentry (Error Tracking — optional) ───────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Revalidation (⚠️ REQUIRED) ──────────────
# Used by POST /api/revalidate to bust config cache
# 🔒 SECRET — generate with: openssl rand -base64 32
REVALIDATION_SECRET=

# ── Template Seed Config (optional) ──────────
# Override these to customize the seed data per client
STORE_NAME=My Store
STORE_CURRENCY=eur
STORE_COUNTRY=es
STORE_REGION_NAME=España
WAREHOUSE_NAME=Main Warehouse
WAREHOUSE_CITY=Valencia

