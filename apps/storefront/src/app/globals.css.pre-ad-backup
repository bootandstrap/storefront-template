  --color-brand-50:  #eef3ea;
  --color-brand-100: #dce7d4;
  --color-brand-200: #b9cfaa;
  --color-brand-300: #8fb278;
  --color-brand-400: #6a9a4e;
  --color-brand-500: #4a8030;
  --color-brand-600: #2D5016;
  --color-brand-700: #264413;
  --color-brand-800: #1f380f;
