/* ========================================================================
   UUI ↔ Project Brand Bridge
   Remaps UUI's hardcoded purple brand-* scale to the project's dynamic
   --color-brand via color-mix(). This is now handled in :root above.
   ======================================================================== */


/* ========================================================================
   Dark Mode Tokens — controlled by config.theme_mode via .dark class on <html>
   ======================================================================== */

.dark {
  --theme-sf-0: #0f1a0a;
  --theme-sf-1: #1a2e12;
  --theme-sf-2: #24401a;
  --theme-sf-3: #2e5222;
  --theme-tx: #e8f0e0;
  --theme-tx-sec: #c5d8b8;
  --theme-tx-muted: #a3b89a;
  --theme-shadow-card: 0 1px 3px rgba(0, 0, 0, 0.3);
  --theme-shadow-card-hover: 0 10px 25px rgba(139, 195, 74, 0.15);
  --theme-shadow-glass: 0 8px 32px rgba(0, 0, 0, 0.4);
}

/* Auto mode: respect OS preference only when data-theme="auto" */
@media (prefers-color-scheme: dark) {
  [data-theme="auto"] {
    --theme-sf-0: #0f1a0a;
    --theme-sf-1: #1a2e12;
    --theme-sf-2: #24401a;
    --theme-sf-3: #2e5222;
    --theme-tx: #e8f0e0;
    --theme-tx-sec: #c5d8b8;
    --theme-tx-muted: #a3b89a;
    --theme-shadow-card: 0 1px 3px rgba(0, 0, 0, 0.3);
    --theme-shadow-card-hover: 0 10px 25px rgba(139, 195, 74, 0.15);
    --theme-shadow-glass: 0 8px 32px rgba(0, 0, 0, 0.4);
  }
}

/* ========================================================================
   Base Styles
   ======================================================================== */

html {
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  background: var(--color-sf-0);
  color: var(--color-tx);
  font-family: var(--font-sans);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ========================================================================
   Accessibility — Focus Visible
   ======================================================================== */

/* Keyboard-only focus ring (invisible for mouse users) */
:focus-visible {
  outline: 2px solid var(--color-accent);
  outline-offset: 2px;
  border-radius: 4px;
}

/* Remove default outline for mouse users */
:focus:not(:focus-visible) {
  outline: none;
}

/* Skip-to-content link (screen reader accessible) */
.skip-to-content {
  position: absolute;
  top: -100%;
  left: 1rem;
  z-index: 100;
  padding: 0.75rem 1.5rem;
  background: var(--color-brand);
  color: var(--color-tx-inv);
  border-radius: var(--radius-button);
  font-weight: 600;
  transition: top 0.2s;
}

.skip-to-content:focus {
  top: 1rem;
}

/* ========================================================================
   Glassmorphism Utilities
   ======================================================================== */

.glass {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px) saturate(180%);
  -webkit-backdrop-filter: blur(12px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.glass-strong {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px) saturate(200%);
  -webkit-backdrop-filter: blur(20px) saturate(200%);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

.dark .glass {
  background: rgba(15, 26, 10, 0.7);
  border-color: rgba(139, 195, 74, 0.15);
}


.dark .glass-strong {
  background: rgba(15, 26, 10, 0.85);
  border-color: rgba(139, 195, 74, 0.2);
}

[data-theme="auto"] {
  @media (prefers-color-scheme: dark) {
    & .glass {
      background: rgba(15, 26, 10, 0.7);
      border-color: rgba(139, 195, 74, 0.15);
    }

    & .glass-strong {
      background: rgba(15, 26, 10, 0.85);
      border-color: rgba(139, 195, 74, 0.2);
    }
  }
}

/* ========================================================================
   Panel — Design Tokens & Utilities
   ======================================================================== */

/* Animated stat number counter */
@keyframes countUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Chart bar growth */
@keyframes barGrow {
  from { transform: scaleY(0); }
  to { transform: scaleY(1); }
}

/* Pulse glow for critical usage */
@keyframes criticalPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3); }
  50% { box-shadow: 0 0 12px 4px rgba(239, 68, 68, 0.15); }
}

.stat-value {
  animation: countUp 0.5s var(--ease-smooth) both;
}

/* Mini sparkline chart */
.sparkline {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 32px;
}

.sparkline-bar {
  flex: 1;
  border-radius: 2px;
  background: var(--color-brand);
  opacity: 0.3;
  transform-origin: bottom;
  animation: barGrow 0.5s var(--ease-spring) both;
  transition: opacity 0.2s;
}

.sparkline-bar:last-child {
  opacity: 0.8;
}

.sparkline-bar:hover {
  opacity: 1;
}

/* Trend indicators */
.trend-up {
  color: #16a34a;
  background: rgba(22, 163, 74, 0.08);
}

.trend-down {
  color: #dc2626;
  background: rgba(220, 38, 38, 0.08);
}

.trend-neutral {
  color: var(--color-tx-muted);
  background: var(--color-sf-2);
}

/* Notification badge dot */
.badge-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ef4444;
  border: 2px solid var(--color-sf-0);
  position: absolute;
  top: -2px;
  right: -2px;
}

.badge-count {
  min-width: 18px;
  height: 18px;
  border-radius: 9px;
  background: #ef4444;
  color: white;
  font-size: 10px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
}

/* Plan badge in sidebar footer */
.plan-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  border-radius: var(--radius-pill);
  font-size: 11px;
  font-weight: 600;
  background: linear-gradient(135deg, var(--color-brand), var(--color-sec));
  color: white;
  letter-spacing: 0.02em;
}

/* Usage meter critical state */
.usage-critical {
  animation: criticalPulse 2s ease-in-out infinite;
}

/* Quick action card */
.quick-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 1.25rem 1rem;
  border-radius: var(--radius-card);
  background: var(--color-sf-0);
  border: 1px solid var(--color-sf-2);
  transition: all 0.2s var(--ease-smooth);
  cursor: pointer;
  text-decoration: none;
  color: var(--color-tx);
}

.quick-action:hover {
  border-color: var(--color-brand);
  transform: translateY(-2px);
  box-shadow: var(--shadow-card-hover);
}

.quick-action-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-brand), var(--color-sec));
  color: white;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 3rem 2rem;
  max-width: 420px;
  margin: 0 auto;
}

.empty-state-icon {
  width: 80px;
  height: 80px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-sf-1), var(--color-sf-2));
  margin-bottom: 1.5rem;
}

/* Sidebar active link indicator */
.sidebar-link-active {
  position: relative;
  background: var(--color-brand) / 0.08;
}

.sidebar-link-active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 4px;
  bottom: 4px;
  width: 3px;
  border-radius: 0 3px 3px 0;
  background: linear-gradient(180deg, var(--color-brand), var(--color-sec));
}

/* Funnel chart bars */
.funnel-bar {
  height: 28px;
  border-radius: 6px;
  background: linear-gradient(90deg, var(--color-brand), var(--color-sec));
  transition: width 0.6s var(--ease-spring);
  min-width: 24px;
}

/* ========================================================================
   Product Card
   ======================================================================== */

.product-card {
  border-radius: var(--radius-card);
  background: var(--color-sf-0);
  box-shadow: var(--shadow-card);
  transition:
    transform 0.3s var(--ease-spring),
    box-shadow 0.3s var(--ease-smooth),
    border-color 0.3s var(--ease-smooth);
  border: 1px solid transparent;
  overflow: hidden;
}

.product-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-card-hover);
  border-color: var(--color-sec);
}

.product-card .product-card-image {
  overflow: hidden;
}

.product-card:hover .product-card-image img {
  transform: scale(1.05);
}

.product-card .product-card-image img {
  transition: transform 0.4s var(--ease-smooth);
}

/* ========================================================================
   Buttons
   ======================================================================== */

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-weight: 600;
  font-size: 0.9375rem;
  border-radius: var(--radius-button);
  padding: 0.75rem 1.5rem;
  transition: all 0.2s var(--ease-smooth);
  cursor: pointer;
  border: none;
  outline: none;
  position: relative;
  overflow: hidden;
}

.btn:active {
  transform: scale(0.97);
}

.btn-primary {
  background: var(--color-brand);
  color: var(--color-tx-inv);
}

.btn-primary:hover {
  background: var(--color-brand-light);
  box-shadow: 0 4px 15px rgba(45, 80, 22, 0.3);
}

.btn-secondary {
  background: var(--color-sf-2);
  color: var(--color-tx);
}

.btn-secondary:hover {
  background: var(--color-sf-3);
}

.btn-ghost {
  background: transparent;
  color: var(--color-tx);
}

.btn-ghost:hover {
  background: var(--color-sf-1);
}

.btn-whatsapp {
  background: #25D366;
  color: #ffffff;
}

.btn-whatsapp:hover {
  background: #20bd5a;
  box-shadow: 0 4px 15px rgba(37, 211, 102, 0.35);
}

.btn-accent {
  background: var(--color-accent);
  color: #ffffff;
}

.btn-accent:hover {
  background: var(--color-accent-light);
}

.btn-danger {
  background: #ef4444;
  color: #ffffff;
}

.btn-danger:hover {
  background: #dc2626;
  box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
}

/* ========================================================================
   Form Inputs
   ======================================================================== */

.input {
  width: 100%;
  padding: 0.625rem 0.875rem;
  font-size: 0.875rem;
  border-radius: var(--radius-button);
  border: 1px solid var(--color-sf-3);
  background: var(--color-sf-0);
  color: var(--color-tx);
  transition: border-color 0.2s, box-shadow 0.2s;
}

.input::placeholder {
  color: var(--color-tx-muted);
}

.input:focus {
  outline: none;
  border-color: var(--color-brand);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-brand) 15%, transparent);
}

.dark .input {
  background: var(--color-sf-1);
  border-color: var(--color-sf-3);
}

[data-theme="auto"] {
  @media (prefers-color-scheme: dark) {
    & .input {
      background: var(--color-sf-1);
      border-color: var(--color-sf-3);
    }
  }
}

/* ========================================================================
   Skeleton Shimmer Animation
   ======================================================================== */

@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }

  100% {
    background-position: 200% 0;
  }
}

.skeleton {
  background: linear-gradient(90deg,
      var(--color-sf-2) 25%,
      var(--color-sf-1) 50%,
      var(--color-sf-2) 75%);
  background-size: 200% 100%;
  animation: shimmer 2s ease-in-out infinite;
  border-radius: var(--radius-button);
}

/* ========================================================================
   Micro-animations
   ======================================================================== */

@keyframes pulse-badge {

  0%,
  100% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.2);
  }
}

@keyframes slide-up {
  from {
    opacity: 0;
    transform: translateY(12px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slide-in-right {
  from {
    transform: translateX(100%);
  }

  to {
    transform: translateX(0);
  }
}

@keyframes slide-out-right {
  from {
    transform: translateX(0);
  }

  to {
    transform: translateX(100%);
  }
}

@keyframes fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes fly-to-cart {
  0% {
    opacity: 1;
    transform: scale(1) translate(0, 0);
  }

  100% {
    opacity: 0;
    transform: scale(0.3) translate(var(--fly-x, 100px), var(--fly-y, -200px));
  }
}

.animate-pulse-badge {
  animation: pulse-badge 0.4s var(--ease-spring);
}

.animate-slide-up {
  animation: slide-up 0.3s var(--ease-smooth) both;
}

.animate-slide-in-right {
  animation: slide-in-right 0.3s var(--ease-smooth);
}

.animate-slide-out-right {
  animation: slide-out-right 0.3s var(--ease-smooth);
}

.animate-fade-in {
  animation: fade-in 0.2s var(--ease-smooth);
}

.animate-slide-right {
  animation: slide-in-right 0.3s var(--ease-smooth);
}

/* ========================================================================
   Onboarding — Welcome Modal & Panel Tour Animations
   ======================================================================== */

@keyframes confetti {
  0% {
    opacity: 0;
    transform: translateY(0) rotate(0deg) scale(0);
  }

  10% {
    opacity: 1;
    transform: translateY(-20px) rotate(30deg) scale(1);
  }

  100% {
    opacity: 0;
    transform: translateY(-300px) rotate(720deg) scale(0.5);
  }
}

@keyframes bounce-slow {

  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-8px);
  }
}

@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(12px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-confetti {
  animation: confetti 2.5s ease-out forwards;
}

.animate-bounce-slow {
  animation: bounce-slow 2s var(--ease-smooth) infinite;
}

.animate-fade-in-up {
  animation: fade-in-up 0.6s var(--ease-smooth) both;
}

.animate-fade-in-up-delay {
  animation: fade-in-up 0.6s var(--ease-smooth) 0.2s both;
}

/* Gamification animations */
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 4px rgba(34, 197, 94, 0.3); }
  50% { box-shadow: 0 0 12px rgba(34, 197, 94, 0.6); }
}

.animate-pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}

@keyframes pulse-subtle {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.85; }
}

.animate-pulse-subtle {
  animation: pulse-subtle 2s ease-in-out infinite;
}

@keyframes shimmer-slide {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.animate-shimmer {
  animation: shimmer-slide 3s ease-in-out infinite;
}

.bg-gradient-radial {
  background: radial-gradient(circle at center, var(--tw-gradient-from, transparent), var(--tw-gradient-via, transparent), var(--tw-gradient-to, transparent));
}

/* ========================================================================
   Toast Notifications
   ======================================================================== */

@keyframes toast-in {
  from {
    opacity: 0;
    transform: translateY(16px) scale(0.95);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes toast-out {
  from {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  to {
    opacity: 0;
    transform: translateY(16px) scale(0.95);
  }
}

.toast-enter {
  animation: toast-in 0.3s var(--ease-spring);
}

.toast-exit {
  animation: toast-out 0.2s var(--ease-smooth) forwards;
}

/* Toast progress bar countdown */
@keyframes toast-progress {
  from {
    width: 100%;
  }

  to {
    width: 0%;
  }
}

.toast-progress-bar {
  animation: toast-progress linear forwards;
}

/* ========================================================================
   Layout Utilities
   ======================================================================== */

.container-page {
  width: 100%;
  max-width: 80rem;
  margin-left: auto;
  margin-right: auto;
  padding-left: 1rem;
  padding-right: 1rem;
}

@media (min-width: 640px) {
  .container-page {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }
}

@media (min-width: 1024px) {
  .container-page {
    padding-left: 2rem;
    padding-right: 2rem;
  }
}

/* WhatsApp floating CTA */
.whatsapp-float {
  position: fixed;
  bottom: 1.5rem;
  right: 1.5rem;
  z-index: 40;
  width: 3.5rem;
  height: 3.5rem;
  border-radius: 9999px;
  background: #25D366;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
  transition: transform 0.2s var(--ease-spring), box-shadow 0.2s, opacity 0.2s var(--ease-smooth);
}

.whatsapp-float:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 30px rgba(37, 211, 102, 0.5);
}

/* Hide WhatsApp float when a drawer or modal is open */
body.drawer-open .whatsapp-float {
  opacity: 0;
  pointer-events: none;
}

/* ========================================================================
   CMS Content Prose Styles
   ======================================================================== */

.cms-content h2 {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-tx);
  margin-top: 2rem;
  margin-bottom: 0.75rem;
}

.cms-content h3 {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--color-tx);
  margin-top: 1.5rem;
  margin-bottom: 0.5rem;
}

.cms-content p {
  margin-bottom: 1rem;
  line-height: 1.8;
}

.cms-content ul,
.cms-content ol {
  margin-bottom: 1rem;
  padding-left: 1.5rem;
}

.cms-content li {
  margin-bottom: 0.5rem;
}

.cms-content a {
  color: var(--color-brand);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.cms-content a:hover {
  color: var(--color-brand-light);
}

.cms-content blockquote {
  border-left: 4px solid var(--color-brand);
  padding-left: 1rem;
  margin: 1.5rem 0;
  font-style: italic;
  color: var(--color-tx-muted);
}

.cms-content img {
  border-radius: var(--radius-card);
  max-width: 100%;
  height: auto;
  margin: 1.5rem 0;
}

/* ========================================================================
   Scrollbar
   ======================================================================== */

::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-track {
  background: var(--color-sf-1);
}

::-webkit-scrollbar-thumb {
  background: var(--color-sf-3);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--color-tx-muted);
}

/* ========================================================================
   Product Badge
   ======================================================================== */

.product-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.25rem 0.625rem;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  border-radius: var(--radius-pill);
  line-height: 1;
  white-space: nowrap;
}

.product-badge-new {
  background: var(--color-brand);
  color: var(--color-tx-inv);
}

.product-badge-offer {
  background: var(--color-accent);
  color: #ffffff;
}

.product-badge-soldout {
  background: var(--color-sf-3);
  color: var(--color-tx-sec);
}

/* ========================================================================
   Template-Agnostic Image Fallback
   ======================================================================== */

.image-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg,
      var(--color-sf-1) 0%,
      var(--color-sf-2) 50%,
      var(--color-sf-1) 100%);
}

.image-fallback svg {
  width: 3rem;
  height: 3rem;
  color: var(--color-tx-muted);
  opacity: 0.5;
}

/* ========================================================================
   Scroll-Reveal Animations
   ======================================================================== */

@keyframes reveal-up {
  from {
    opacity: 0;
    transform: translateY(24px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s var(--ease-smooth), transform 0.6s var(--ease-smooth);
}

.reveal.revealed {
  opacity: 1;
  transform: translateY(0);
}

/* Stagger delays for grid children */
.stagger-1 {
  transition-delay: 0.05s;
}

.stagger-2 {
  transition-delay: 0.1s;
}

.stagger-3 {
  transition-delay: 0.15s;
}

.stagger-4 {
  transition-delay: 0.2s;
}

.stagger-5 {
  transition-delay: 0.25s;
}

.stagger-6 {
  transition-delay: 0.3s;
}

.stagger-7 {
  transition-delay: 0.35s;
}

.stagger-8 {
  transition-delay: 0.4s;
}

/* ========================================================================
   Card Lift — Hover elevation for interactive cards
   ======================================================================== */

.card-lift {
  transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-smooth);
}

.card-lift:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-card-hover);
}

/* ========================================================================
   Count Bump — Quantity change animation
   ======================================================================== */

@keyframes count-bump {
  0% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.3);
  }

  100% {
    transform: scale(1);
  }
}

.animate-count-bump {
  animation: count-bump 0.2s var(--ease-spring);
}

/* ========================================================================
   Section Divider — Soft visual rhythm between homepage sections
   ======================================================================== */

.section-divider {
  border: none;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--color-sf-3), transparent);
  margin: 0 auto;
  max-width: 60%;
}

/* ========================================================================
   Touch Target — WCAG 2.5.5 minimum 44px
   ======================================================================== */

.touch-target {
  min-width: 2.75rem;
  min-height: 2.75rem;
}

/* ========================================================================
   iOS Safe Area Support
   ======================================================================== */

@supports (padding: env(safe-area-inset-bottom)) {
  .whatsapp-float {
    bottom: calc(1.5rem + env(safe-area-inset-bottom));
  }

  .safe-area-bottom {
    padding-bottom: env(safe-area-inset-bottom);
  }
}

/* ========================================================================
   Accessibility — Reduced Motion
   ======================================================================== */

@media (prefers-reduced-motion: reduce) {

  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* ========================================================================
   Image Zoom — Hover lens + fullscreen gallery
   ======================================================================== */

.image-zoom-container {
  position: relative;
  overflow: hidden;
  cursor: zoom-in;
  border-radius: var(--radius-card);
}

.image-zoom-base {
  width: 100%;
  height: auto;
  display: block;
  transition: opacity 0.2s;
}

.image-zoom-lens {
  position: absolute;
  inset: 0;
  z-index: 10;
  pointer-events: none;
  background-repeat: no-repeat;
  opacity: 1;
}

.image-zoom-hint {
  position: absolute;
  bottom: 0.75rem;
  right: 0.75rem;
  z-index: 5;
  padding: 0.5rem;
  border-radius: var(--radius-pill);
  background: rgba(0, 0, 0, 0.5);
  color: white;
  opacity: 0;
  transition: opacity 0.2s;
}

.image-zoom-container:hover .image-zoom-hint {
  opacity: 1;
}

/* Touch devices — no hover lens */
@media (hover: none) {
  .image-zoom-lens {
    display: none;
  }

  .image-zoom-hint {
    opacity: 1;
  }
}

/* Fullscreen overlay */
.image-zoom-fullscreen {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fade-in 0.2s var(--ease-smooth);
}

.image-zoom-fullscreen-image {
  position: relative;
  width: 90vw;
  height: 80vh;
  max-width: 1200px;
}

.image-zoom-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  z-index: 110;
  padding: 0.75rem;
  border-radius: 9999px;
  background: rgba(255, 255, 255, 0.15);
  color: white;
  border: none;
  cursor: pointer;
  transition: background 0.2s;
}

.image-zoom-close:hover {
  background: rgba(255, 255, 255, 0.3);
}

.image-zoom-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 110;
  padding: 0.75rem;
  border-radius: 9999px;
  background: rgba(255, 255, 255, 0.15);
  color: white;
  border: none;
  cursor: pointer;
  transition: background 0.2s;
}

.image-zoom-nav:hover {
  background: rgba(255, 255, 255, 0.3);
}

.image-zoom-nav-prev {
  left: 1rem;
}

.image-zoom-nav-next {
  right: 1rem;
}

.image-zoom-dots {
  position: absolute;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 0.5rem;
  z-index: 110;
}

.image-zoom-dot {
  width: 8px;
  height: 8px;
  border-radius: 9999px;
  background: rgba(255, 255, 255, 0.4);
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}

.image-zoom-dot.active {
  background: white;
  transform: scale(1.3);
}

/* ========================================================================
   Scrollbar Hide — for horizontal scroll sections (recently viewed)
   ======================================================================== */

.scrollbar-hide {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.scrollbar-hide::-webkit-scrollbar {
  display: none;
}

/* ========================================================================
   Quick View Modal
   ======================================================================== */

.quick-view-trigger {
  padding: 0.5rem;
  border-radius: 9999px;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}

.quick-view-trigger:hover {
  background: var(--color-brand);
  transform: scale(1.1);
}

.quick-view-overlay {
  position: fixed;
  inset: 0;
  z-index: 90;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
  animation: fade-in 0.15s;
}

.quick-view-modal {
  position: relative;
  background: var(--color-sf-0);
  border-radius: 1.5rem;
  max-width: 48rem;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: var(--shadow-float);
}

.quick-view-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  z-index: 10;
  padding: 0.5rem;
  border-radius: 9999px;
  background: var(--color-sf-2);
  color: var(--color-tx);
  border: none;
  cursor: pointer;
  transition: background 0.2s;
}

.quick-view-close:hover {
  background: var(--color-sf-3);
}

.quick-view-content {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  padding: 1.5rem;
}

@media (min-width: 640px) {
  .quick-view-content {
    grid-template-columns: 1fr 1fr;
    padding: 2rem;
  }
}

.quick-view-image {
  position: relative;
  aspect-ratio: 1;
  border-radius: var(--radius-card);
  overflow: hidden;
  background: var(--color-sf-1);
}

.quick-view-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* ========================================================================
   Mega Menu — Category dropdown
   ======================================================================== */

.mega-menu-container {
  position: relative;
}

.mega-menu-trigger {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-weight: 500;
  color: var(--color-tx);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
  border-radius: var(--radius-button);
  transition: color 0.2s, background 0.2s;
}

.mega-menu-trigger:hover {
  color: var(--color-brand);
  background: var(--color-sf-1);
}

.mega-menu-dropdown {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  z-index: 50;
  min-width: 20rem;
  max-width: 40rem;
  background: var(--color-sf-0);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-float);
  border: 1px solid var(--color-sf-2);
  padding: 1.5rem;
  margin-top: 0.5rem;
}

.mega-menu-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
  gap: 1.5rem;
}

.mega-menu-category {
  display: block;
  font-weight: 700;
  font-size: 0.875rem;
  color: var(--color-tx);
  margin-bottom: 0.5rem;
  text-decoration: none;
  transition: color 0.2s;
}

.mega-menu-category:hover {
  color: var(--color-brand);
}

.mega-menu-subcategories {
  list-style: none;
  padding: 0;
  margin: 0;
}

.mega-menu-subcategory {
  display: block;
  font-size: 0.8125rem;
  color: var(--color-tx-sec);
  padding: 0.25rem 0;
  text-decoration: none;
  transition: color 0.2s;
}

.mega-menu-subcategory:hover {
  color: var(--color-brand);
}

/* ========================================================================
   Price Range Filter
   ======================================================================== */

.price-range-inputs {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.price-range-inputs .input {
  max-width: 6rem;
  padding: 0.375rem 0.5rem;
  font-size: 0.8125rem;
  text-align: center;
}

/* ===== Bottom Navigation (mobile-only) ===== */
.bottom-nav {
  display: none;
  /* hidden on desktop */
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 40;
  background: color-mix(in srgb, var(--color-surface) 85%, transparent);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1px solid var(--color-border);
  padding-bottom: env(safe-area-inset-bottom, 0);
}

@media (max-width: 767px) {
  .bottom-nav {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding-top: 0.5rem;
    padding-bottom: calc(0.5rem + env(safe-area-inset-bottom, 0));
  }

  /* Add space at bottom of page so content isn't hidden behind nav */
  main {
    padding-bottom: calc(4rem + env(safe-area-inset-bottom, 0));
  }
}

.bottom-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  padding: 0.25rem 0.75rem;
  color: var(--color-tx-muted);
  text-decoration: none;
  transition: color 0.15s ease;
}

.bottom-nav-item--active {
  color: var(--color-brand);
}

.bottom-nav-badge {
  position: absolute;
  top: -6px;
  right: -8px;
  min-width: 16px;
  height: 16px;
  border-radius: 99px;
  background: var(--color-brand);
  color: white;
  font-size: 10px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
}

/* ===== RTL support (future locales: ar, he, fa, ur) ===== */
[dir="rtl"] {
  text-align: right;
}

[dir="rtl"] .flex-row {
  flex-direction: row-reverse;
}

[dir="rtl"] .ml-auto {
  margin-left: 0;
  margin-right: auto;
}

[dir="rtl"] .mr-auto {
  margin-right: 0;
  margin-left: auto;
}

/* ========================================================================
   Gamification — Achievements, Health Ring, Celebrations
   ======================================================================== */

/* Achievement badge card */
.achievement-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 0.75rem;
  border-radius: var(--radius-card);
  background: var(--color-sf-1);
  border: 1px solid var(--color-sf-3);
  transition: all 0.3s var(--ease-smooth);
  text-align: center;
}

.achievement-badge.unlocked {
  border-color: var(--color-brand);
  background: linear-gradient(135deg, color-mix(in srgb, var(--color-brand) 5%, var(--color-sf-1)), var(--color-sf-1));
  box-shadow: 0 0 12px color-mix(in srgb, var(--color-brand) 15%, transparent);
}

.achievement-badge.locked {
  opacity: 0.45;
  filter: grayscale(0.8);
}

.achievement-badge.locked:hover {
  opacity: 0.7;
  filter: grayscale(0.4);
}

@keyframes glow-pulse {
  0%, 100% {
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-brand) 20%, transparent);
  }
  50% {
    box-shadow: 0 0 20px color-mix(in srgb, var(--color-brand) 35%, transparent);
  }
}

.achievement-badge.newly-unlocked {
  animation: glow-pulse 2s ease-in-out 3;
}

/* Health ring */
@keyframes progress-fill {
  from {
    stroke-dasharray: 0 251.33;
  }
}

.health-ring {
  transition: stroke-dasharray 1s var(--ease-spring);
}

@keyframes score-count {
  from { opacity: 0; transform: scale(0.5); }
  50% { transform: scale(1.15); }
  to { opacity: 1; transform: scale(1); }
}

.animate-score-count {
  animation: score-count 0.6s var(--ease-spring) 0.3s both;
}

/* Celebration toast */
@keyframes celebrate-in {
  0% {
    opacity: 0;
    transform: translateX(100%) scale(0.8);
  }
  60% {
    transform: translateX(-8px) scale(1.02);
  }
  100% {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
}

@keyframes celebrate-shake {
  0%, 100% { transform: rotate(0deg); }
  15% { transform: rotate(-8deg); }
  30% { transform: rotate(8deg); }
  45% { transform: rotate(-5deg); }
  60% { transform: rotate(5deg); }
  75% { transform: rotate(-2deg); }
}

.celebrate-toast-enter {
  animation: celebrate-in 0.5s var(--ease-spring);
}

.celebrate-emoji {
  animation: celebrate-shake 0.6s var(--ease-spring) 0.3s both;
}

/* Confetti burst (for celebrations) */
@keyframes confetti-burst {
  0% {
    opacity: 1;
    transform: translate(0, 0) rotate(0deg) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate(var(--confetti-x, 40px), var(--confetti-y, -80px)) rotate(var(--confetti-r, 360deg)) scale(0.3);
  }
}

.confetti-particle {
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 2px;
  animation: confetti-burst 0.8s ease-out forwards;
  pointer-events: none;
}

/* Smart tip */
.smart-tip {
  position: relative;
  padding: 0.875rem 1rem;
  border-radius: var(--radius-card);
  background: linear-gradient(135deg, color-mix(in srgb, var(--color-brand) 6%, var(--color-sf-1)), var(--color-sf-1));
  border: 1px solid color-mix(in srgb, var(--color-brand) 20%, var(--color-sf-3));
  animation: slide-up 0.3s var(--ease-smooth) both;
}

.smart-tip-dismiss {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
  color: var(--color-tx-muted);
  cursor: pointer;
  transition: all 0.2s;
  border: none;
  padding: 0;
}

.smart-tip-dismiss:hover {
  background: var(--color-sf-2);
  color: var(--color-tx);
}

/* Level badges */
.level-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: var(--radius-pill);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.03em;
  text-transform: uppercase;
}

.level-badge-setup {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: white;
}

.level-badge-growing {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: white;
}

.level-badge-thriving {
  background: linear-gradient(135deg, #10b981, #059669);
  color: white;
}

/* ═══════════════════════════════════════════════════
 * POS Fullscreen Mode
 * Body class toggled by POSClient via useEffect.
 * Hides panel sidebar + topbar for distraction-free POS.
 * ═══════════════════════════════════════════════════ */

/* Hide desktop sidebar */
body.pos-fullscreen aside.hidden.md\:flex {
  display: none !important;
}

/* Hide mobile sidebar overlay */
body.pos-fullscreen .md\:hidden.fixed.inset-0.z-50 {
  display: none !important;
}

/* Remove topbar */
body.pos-fullscreen [data-panel-topbar] {
  display: none !important;
}

/* Remove content area constraints */
body.pos-fullscreen .max-w-6xl {
  max-width: none;
  padding: 0;
  margin: 0;
}

/* Ensure full height */
body.pos-fullscreen {
  overflow: hidden;
}

/* ── POS Grid Layout (viewport-locked 65/35 split) ── */
.pos-grid {
  display: grid;
  grid-template-columns: 1fr minmax(320px, 35%);
  height: 100%;
  min-height: 0;
  flex: 1;
  overflow: hidden;
}

/* Mobile: full-height products + bottom cart mini-bar */
@media (max-width: 767px) {
  .pos-grid {
    grid-template-columns: 1fr;
    grid-template-rows: 1fr auto;
  }
}

/* ── POS Viewport Lock ── */
/* NOTE: PanelShell already sets h-dvh + overflow-hidden when isPOS.
   pos-viewport fills that container — do NOT use 100dvh here. */
.pos-viewport {
  height: 100%;
  max-height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--color-sf-0, #fff);
}

/* ── POS Cart Sidebar ── */
.pos-cart-sidebar {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  overflow: hidden;
}

.pos-cart-sidebar__items {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.pos-cart-sidebar__footer {
  flex-shrink: 0;
  padding-bottom: env(safe-area-inset-bottom, 0px);
}

/* ── POS Product Panel (only scrollable area) ── */
.pos-products-panel {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  min-height: 0;
  height: 100%;
}

/* ── Mobile Cart Bottom Sheet ── */
@media (max-width: 767px) {
  .pos-cart-minibar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background: var(--color-sf-0, #fff);
    border-top: 1px solid var(--color-sf-2, #e5e7eb);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .pos-cart-sheet {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .pos-cart-sheet__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
  }

  .pos-cart-sheet__panel {
    position: relative;
    max-height: 85dvh;
    border-radius: 1.25rem 1.25rem 0 0;
    background: var(--color-sf-0, #fff);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  .pos-cart-sheet__handle {
    width: 2.5rem;
    height: 0.25rem;
    border-radius: 9999px;
    background: var(--color-sf-3, #d1d5db);
    margin: 0.5rem auto;
    flex-shrink: 0;
  }
}
