{
    "name": "@bootandstrap/shared",
    "version": "0.4.0",
    "description": "Shared types, governance, billing, provisioning, and module registry for BootandStrap platform",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./billing": {
            "types": "./dist/billing/index.d.ts",
            "import": "./dist/billing/index.js",
            "default": "./dist/billing/index.js"
        },
        "./governance": {
            "types": "./dist/governance/index.d.ts",
            "import": "./dist/governance/index.js",
            "default": "./dist/governance/index.js"
        },
        "./provisioning": {
            "types": "./dist/provisioning/index.d.ts",
            "import": "./dist/provisioning/index.js",
            "default": "./dist/provisioning/index.js"
        },
        "./modules": {
            "types": "./dist/modules/index.d.ts",
            "import": "./dist/modules/index.js",
            "default": "./dist/modules/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:run": "vitest run",
        "test:watch": "vitest",
        "changeset": "changeset",
        "version": "changeset version",
        "release": "npm run build && changeset publish",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run clean && npm run build"
    },
    "dependencies": {},
    "peerDependencies": {
        "stripe": ">=14.0.0"
    },
    "peerDependenciesMeta": {
        "stripe": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.9.0",
        "vitest": "^3.0.0"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com",
        "access": "restricted"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/bootandstrap/storefront-template.git",
        "directory": "packages/shared"
    },
    "license": "UNLICENSED"
}
